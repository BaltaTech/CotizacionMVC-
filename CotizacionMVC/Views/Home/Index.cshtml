@{
    ViewData["Title"] = "Inicio";
}

<div class="home-container">
    
    @* ========== HERO ========== *@
    <div class="hero-section">
        <div class="hero-icon">
            <i class="fas fa-wind"></i>
        </div>
        <h1 class="hero-title">HVAC Pro</h1>
        <p class="hero-subtitle">Sistema de Cotizaciones</p>
        <p class="hero-description">Administra tus oportunidades, clientes y cotizaciones desde un solo lugar.</p>
    </div>

    @* ========== NAVIGATION CARDS ========== *@
    <div class="nav-grid">
        
        <a asp-controller="Cotizacion" asp-action="Indice" class="nav-card">
            <div class="nav-card-icon" style="background:#fff3e0;color:#e65100;">
                <i class="fas fa-lightbulb"></i>
            </div>
            <div class="nav-card-content">
                <h3 class="nav-card-title">Oportunidades</h3>
                <p class="nav-card-description">Leads y pipeline de ventas</p>
            </div>
            <i class="fas fa-arrow-right nav-card-arrow"></i>
        </a>

        <a asp-controller="Cotizacion" asp-action="Crear" class="nav-card">
            <div class="nav-card-icon" style="background:#fce4e4;color:#c62828;">
                <i class="fas fa-plus-circle"></i>
            </div>
            <div class="nav-card-content">
                <h3 class="nav-card-title">Nueva Cotización</h3>
                <p class="nav-card-description">Crear cotización desde cero</p>
            </div>
            <i class="fas fa-arrow-right nav-card-arrow"></i>
        </a>

        <a asp-controller="Cliente" asp-action="Indice" class="nav-card">
            <div class="nav-card-icon" style="background:#e3f2fd;color:#1565c0;">
                <i class="fas fa-address-book"></i>
            </div>
            <div class="nav-card-content">
                <h3 class="nav-card-title">Clientes</h3>
                <p class="nav-card-description">Administrar base de clientes</p>
            </div>
            <i class="fas fa-arrow-right nav-card-arrow"></i>
        </a>

        <a asp-controller="Equipo" asp-action="Catalogo" class="nav-card">
            <div class="nav-card-icon" style="background:#e8f5e9;color:#2e7d32;">
                <i class="fas fa-microchip"></i>
            </div>
            <div class="nav-card-content">
                <h3 class="nav-card-title">Catálogo HVAC</h3>
                <p class="nav-card-description">Equipos y materiales</p>
            </div>
            <i class="fas fa-arrow-right nav-card-arrow"></i>
        </a>

        <a asp-controller="Instalacion" asp-action="Catalogo" class="nav-card">
            <div class="nav-card-icon" style="background:#f3e5f5;color:#7b1fa2;">
                <i class="fas fa-tools"></i>
            </div>
            <div class="nav-card-content">
                <h3 class="nav-card-title">Instalaciones</h3>
                <p class="nav-card-description">Servicios y mano de obra</p>
            </div>
            <i class="fas fa-arrow-right nav-card-arrow"></i>
        </a>

        <a asp-controller="Seguimiento" asp-action="Dashboard" class="nav-card">
            <div class="nav-card-icon" style="background:#e0f7fa;color:#00838f;">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="nav-card-content">
                <h3 class="nav-card-title">Seguimientos</h3>
                <p class="nav-card-description">Historial de actividades</p>
            </div>
            <i class="fas fa-arrow-right nav-card-arrow"></i>
        </a>
    </div>

    @* ========== QUICK STATS (opcional, si quieres datos reales después) ========== *@
    <div class="stats-row">
        <div class="stat-item">
            <span class="stat-value">—</span>
            <span class="stat-label">Cotizaciones activas</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-value">—</span>
            <span class="stat-label">Clientes registrados</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-value">—</span>
            <span class="stat-label">Leads pendientes</span>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* ===== CONTAINER ===== */
        .home-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        /* ===== HERO ===== */
        .hero-section {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .hero-icon {
            width: 72px;
            height: 72px;
            border-radius: 18px;
            background: #fce4e4;
            color: #c62828;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 1.25rem;
        }

        .hero-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 0.25rem;
        }

        .hero-subtitle {
            font-size: 1rem;
            color: #c62828;
            font-weight: 500;
            margin-bottom: 0.75rem;
        }

        .hero-description {
            font-size: 0.9rem;
            color: #888;
            max-width: 400px;
            margin: 0 auto;
            line-height: 1.5;
        }

        /* ===== NAVIGATION GRID ===== */
        .nav-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .nav-card {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.25rem;
            background: white;
            border: 1px solid #eee;
            border-radius: 12px;
            text-decoration: none;
            transition: all 0.2s ease;
            position: relative;
            overflow: hidden;
        }

            .nav-card:hover {
                border-color: #e0e0e0;
                box-shadow: 0 4px 16px rgba(0,0,0,0.06);
                transform: translateY(-2px);
            }

        .nav-card-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .nav-card-content {
            flex: 1;
            min-width: 0;
        }

        .nav-card-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: #222;
            margin-bottom: 0.2rem;
        }

        .nav-card-description {
            font-size: 0.8rem;
            color: #999;
            margin: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .nav-card-arrow {
            color: #ddd;
            font-size: 0.8rem;
            transition: all 0.2s ease;
            flex-shrink: 0;
        }

        .nav-card:hover .nav-card-arrow {
            color: #c62828;
            transform: translateX(2px);
        }

        /* ===== STATS ROW ===== */
        .stats-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
            background: white;
            border: 1px solid #eee;
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
        }

        .stat-item {
            text-align: center;
            flex: 1;
        }

        .stat-value {
            display: block;
            font-size: 1.5rem;
            font-weight: 700;
            color: #333;
        }

        .stat-label {
            display: block;
            font-size: 0.78rem;
            color: #999;
            margin-top: 0.25rem;
        }

        .stat-divider {
            width: 1px;
            height: 40px;
            background: #eee;
            flex-shrink: 0;
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 768px) {
            .nav-grid {
                grid-template-columns: 1fr;
            }

            .stats-row {
                flex-direction: column;
                gap: 1rem;
            }

            .stat-divider {
                width: 60px;
                height: 1px;
            }
        }
    </style>
}