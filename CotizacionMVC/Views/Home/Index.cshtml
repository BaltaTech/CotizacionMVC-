@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-4 py-3">
    
    <div class="row mb-4">
        <div class="col-12">
            <div class="bg-white p-4 rounded shadow-sm text-center">
                <i class="fas fa-temperature-low fa-4x mb-3" style="color: var(--color-primario, #C8102E); opacity: 0.7;"></i>
                <h3 class="fw-bold" style="color: var(--color-primario, #C8102E);">Bienvenido al Sistema HVAC Pro</h3>
                <p class="text-muted mb-0">Seleccione una opción para comenzar</p>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-xl-3 col-md-6">
            <a asp-controller="Cotizacion" asp-action="Indice" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 card-dashboard" style="background: linear-gradient(135deg, #FF6B35, #F7931E);">
                    <div class="card-body text-white text-center py-4">
                        <i class="fas fa-lightbulb fa-3x mb-3" style="opacity: 0.6;"></i>
                        <h5 class="fw-bold">Mis Oportunidades</h5>
                        <p class="mb-0 small" style="opacity: 0.8;">Leads y pipeline de ventas</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-xl-3 col-md-6">
            <a asp-controller="Cotizacion" asp-action="Crear" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 card-dashboard" style="background: linear-gradient(135deg, var(--color-primario, #C8102E), var(--color-primario-oscuro, #A00D25));">
                    <div class="card-body text-white text-center py-4">
                        <i class="fas fa-plus-circle fa-3x mb-3" style="opacity: 0.6;"></i>
                        <h5 class="fw-bold">Nueva Cotización</h5>
                        <p class="mb-0 small" style="opacity: 0.8;">Crear cotización desde cero</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-xl-3 col-md-6">
            <a asp-controller="Cliente" asp-action="Indice" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 card-dashboard" style="background: linear-gradient(135deg, #1A73E8, #4285F4);">
                    <div class="card-body text-white text-center py-4">
                        <i class="fas fa-address-book fa-3x mb-3" style="opacity: 0.6;"></i>
                        <h5 class="fw-bold">Clientes</h5>
                        <p class="mb-0 small" style="opacity: 0.8;">Administrar base de clientes</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-xl-3 col-md-6">
            <a asp-controller="Equipo" asp-action="Indice" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 card-dashboard" style="background: linear-gradient(135deg, #28A745, #20C997);">
                    <div class="card-body text-white text-center py-4">
                        <i class="fas fa-tools fa-3x mb-3" style="opacity: 0.6;"></i>
                        <h5 class="fw-bold">Catálogo HVAC</h5>
                        <p class="mb-0 small" style="opacity: 0.8;">Equipos y materiales</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        .card-dashboard { transition: all 0.3s ease; cursor: pointer; }
        .card-dashboard:hover { transform: translateY(-5px); box-shadow: 0 12px 30px rgba(0,0,0,0.2) !important; }
    </style>
}