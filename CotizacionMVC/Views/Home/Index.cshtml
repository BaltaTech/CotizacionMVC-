@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mt-5">
    <i class="fas fa-snowflake fa-4x text-primary mb-3"></i>
    <h1 class="display-4 fw-bold">CotizacionMVC</h1>
    <p class="lead text-muted">Sistema de Cotizaciones HVAC</p>
    <hr class="my-4 w-50 mx-auto" />

    <div class="row mt-5">
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="fas fa-file-invoice fa-2x text-primary mb-2"></i>
                    <h5>Cotizaciones</h5>
                    <p class="text-muted small">Crear y gestionar cotizaciones</p>
                    <a asp-controller="Cotizacion" asp-action="Indice" class="btn btn-outline-primary btn-sm">Ir</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="fas fa-users fa-2x text-primary mb-2"></i>
                    <h5>Clientes</h5>
                    <p class="text-muted small">Administrar clientes</p>
                    <a asp-controller="Cliente" asp-action="Indice" class="btn btn-outline-primary btn-sm">Ir</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="fas fa-tools fa-2x text-primary mb-2"></i>
                    <h5>Catálogo de Equipos</h5>
                    <p class="text-muted small">Ver equipos disponibles</p>
                    <a asp-controller="Equipo" asp-action="Indice" class="btn btn-outline-primary btn-sm">Ir</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="fas fa-building fa-2x text-primary mb-2"></i>
                    <h5>Empresas</h5>
                    <p class="text-muted small">Configurar empresas</p>
                    <a asp-controller="Empresa" asp-action="Indice" class="btn btn-outline-primary btn-sm">Ir</a>
                </div>
            </div>
        </div>
    </div>
</div>