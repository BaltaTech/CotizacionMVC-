@model IEnumerable<CotizacionMVC.Models.Entidades.Cotizacion>

@{
    ViewData["Title"] = "Cotizaciones";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-file-invoice"></i> Cotizaciones</h1>
        <a asp-action="Crear" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nueva Cotización
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i> No hay cotizaciones registradas.
            <br />
            <a asp-action="Crear" class="btn btn-primary mt-2">Crear la primera cotización</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>N° Cotización</th>
                        <th>Cliente</th>
                        <th>Vendedor</th>           <!-- NUEVA COLUMNA -->
                        <th>Empresa</th>
                        <th>Fecha</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cotizacion in Model)
                    {
                        <tr>
                            <td><strong>@cotizacion.NumeroCotizacion</strong></td>
                            <td>@cotizacion.Cliente?.Nombre</td>
                            <td>@cotizacion.Vendedor?.NombreCompleto</td>   <!-- NUEVA CELDA -->
                            <td>@cotizacion.Empresa?.NombreComercial</td>
                            <td>@cotizacion.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            <td>@cotizacion.Total.ToString()</td>
                            <td>
                                @{
                                    var porcentaje = cotizacion.ObtenerPorcentajeEstado();
                                    string colorBadge = porcentaje >= 90 ? "success" : (porcentaje >= 50 ? "warning" : "info");
                                }
                                <span class="badge bg-@colorBadge">@porcentaje% - @cotizacion.Estado</span>
                            </td>
                            <td>
                                <a asp-action="Detalles" asp-route-id="@cotizacion.Id" class="btn btn-sm btn-info" title="Detalles">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (cotizacion.PuedeSerModificada())
                                {
                                    <a asp-action="Editar" asp-route-id="@cotizacion.Id" class="btn btn-sm btn-warning" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
}