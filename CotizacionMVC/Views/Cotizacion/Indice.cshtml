@model CotizacionMVC.ViewModels.Cotizacion.CotizacionIndiceViewModel

@{
    ViewData["Title"] = "Panel de Ventas";
    var cotizaciones = Model.Cotizaciones;
    var leads = Model.Leads;
    var clientesAsignados = leads.Where(l => l.OrigenLead == 1).ToList();
    var leadsProspeccion = leads.Where(l => l.OrigenLead == 2).ToList();
    var total = cotizaciones.Count();
    var activas = cotizaciones.Count(c => c.Estado != CotizacionMVC.Models.Enums.EstadoCotizacion.Cerrada
                                && c.Estado != CotizacionMVC.Models.Enums.EstadoCotizacion.Perdida);
    var cerradas = cotizaciones.Count(c => c.Estado == CotizacionMVC.Models.Enums.EstadoCotizacion.Cerrada);
    var totalMonto = cotizaciones.Where(c => c.Estado == CotizacionMVC.Models.Enums.EstadoCotizacion.Cerrada).Sum(c => c.Total);
    var pendientesAsignados = clientesAsignados.Count(l => l.Estado == 2 || l.Estado == 3);
    var pendientesProspeccion = leadsProspeccion.Count(l => l.Estado == 2);
}

<div class="container-fluid px-4 py-4">

    @* ========== HEADER ========== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h4 class="fw-bold mb-1">Panel de Ventas</h4>
            <p class="text-muted mb-0 small">Oportunidades y cotizaciones</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Seguimiento" asp-action="CrearLead" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-lightbulb me-1"></i>Nuevo Lead
            </a>
            <a asp-controller="Seguimiento" asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-chart-line me-1"></i>Seguimientos
            </a>
            <a asp-action="Crear" class="btn btn-danger btn-sm">
                <i class="fas fa-plus me-1"></i>Nueva Cotización
            </a>
        </div>
    </div>

    @* ========== KPI CARDS ========== *@
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3 d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-1">Clientes asignados</p>
                        <h3 class="fw-bold mb-0">@clientesAsignados.Count</h3>
                        <small class="text-warning">@pendientesAsignados pendientes</small>
                    </div>
                    <div class="bg-danger bg-opacity-10 rounded-3 p-2">
                        <i class="fas fa-user-check text-danger fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3 d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-1">Leads prospección</p>
                        <h3 class="fw-bold mb-0">@leadsProspeccion.Count</h3>
                        <small class="text-muted">@pendientesProspeccion sin contactar</small>
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded-3 p-2">
                        <i class="fas fa-lightbulb text-warning fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3 d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-1">En proceso</p>
                        <h3 class="fw-bold mb-0">@activas</h3>
                        <small class="text-muted">Cotizaciones activas</small>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-3 p-2">
                        <i class="fas fa-spinner text-primary fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3 d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-1">Cerradas</p>
                        <h3 class="fw-bold mb-0">@cerradas</h3>
                        <small class="text-success">@totalMonto.ToString("C0") MXN</small>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-3 p-2">
                        <i class="fas fa-check-double text-success fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ========== ALERTS ========== *@
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show rounded-3" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm alert-dismissible fade show rounded-3" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ========== TABS OPORTUNIDADES ========== *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <ul class="nav nav-tabs card-header-tabs gap-2" id="oportunidadesTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active px-4" data-bs-toggle="tab" data-bs-target="#clientesPanel" type="button">
                        <i class="fas fa-user-check me-2 text-danger"></i>Clientes Asignados
                        <span class="badge bg-danger ms-2">@clientesAsignados.Count</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link px-4" data-bs-toggle="tab" data-bs-target="#leadsPanel" type="button">
                        <i class="fas fa-lightbulb me-2 text-warning"></i>Mis Leads
                        <span class="badge bg-warning text-dark ms-2">@leadsProspeccion.Count</span>
                    </button>
                </li>
            </ul>
        </div>
        <div class="card-body p-0">
            <div class="tab-content">
                
                @* TAB CLIENTES ASIGNADOS *@
                <div class="tab-pane fade show active" id="clientesPanel">
                    @if (!clientesAsignados.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-user-check fa-3x mb-3 opacity-25"></i>
                            <p class="mb-0">No tienes clientes asignados</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light small text-uppercase text-muted">
                                    <tr>
                                        <th class="ps-4">Cliente</th>
                                        <th>Producto</th>
                                        <th class="text-center">Estado</th>
                                        <th>Fecha</th>
                                        <th class="text-center" style="width:130px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var lead in clientesAsignados)
                                    {
                                        var estadoCliente = (CotizacionMVC.Models.Enums.EstadoCliente)lead.Estado;
                                        var (colorEstado, iconoEstado, textoEstado) = estadoCliente switch
                                        {
                                            CotizacionMVC.Models.Enums.EstadoCliente.Asignado => ("warning", "fa-user-check", "Asignado"),
                                            CotizacionMVC.Models.Enums.EstadoCliente.Contactado => ("info", "fa-phone-alt", "Contactado"),
                                            CotizacionMVC.Models.Enums.EstadoCliente.Cotizado => ("primary", "fa-file-invoice", "Cotizado"),
                                            CotizacionMVC.Models.Enums.EstadoCliente.NoCotizable => ("danger", "fa-ban", "No Cotizable"),
                                            CotizacionMVC.Models.Enums.EstadoCliente.Cerrado => ("success", "fa-check-circle", "Cerrado"),
                                            _ => ("secondary", "fa-circle", estadoCliente.ToString())
                                        };

                                        <tr>
                                            <td class="ps-4">
                                                <strong>@lead.ClienteNombre</strong>
                                                <br><small class="text-muted">@lead.ClienteTelefono</small>
                                            </td>
                                            <td><span class="badge bg-light text-dark">@(lead.ProductoBusca ?? "Sin producto")</span></td>
                                            <td class="text-center">
                                                <span class="badge rounded-pill bg-@colorEstado bg-opacity-10 text-@colorEstado px-3 py-2">
                                                    <i class="fas @iconoEstado me-1"></i>@textoEstado
                                                </span>
                                            </td>
                                            <td><small class="text-muted">@(lead.FechaAsignacion?.ToString("dd MMM") ?? lead.FechaCreacion.ToString("dd MMM"))</small></td>
                                            <td class="text-center">
                                                <a asp-action="Crear" asp-route-leadId="@lead.Id" class="btn btn-sm btn-outline-danger" title="Cotizar">
                                                    <i class="fas fa-plus-circle me-1"></i>Cotizar
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                @* TAB MIS LEADS *@
                <div class="tab-pane fade" id="leadsPanel">
                    @if (!leadsProspeccion.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-lightbulb fa-3x mb-3 opacity-25"></i>
                            <p class="mb-0">No tienes leads de prospección</p>
                            <a asp-controller="Seguimiento" asp-action="CrearLead" class="btn btn-warning btn-sm mt-2">Crear Lead</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light small text-uppercase text-muted">
                                    <tr>
                                        <th class="ps-4">Contacto</th>
                                        <th>Empresa</th>
                                        <th>Producto</th>
                                        <th class="text-center">Estado</th>
                                        <th>Fecha</th>
                                        <th class="text-center" style="width:130px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var lead in leadsProspeccion)
                                    {
                                        var estadoCliente = (CotizacionMVC.Models.Enums.EstadoCliente)lead.Estado;
                                        var (tempColor, tempIcono, tempTexto) = estadoCliente switch
                                        {
                                            CotizacionMVC.Models.Enums.EstadoCliente.Contactado => ("warning", "fa-thermometer-half", "Contactado"),
                                            CotizacionMVC.Models.Enums.EstadoCliente.Cotizado => ("danger", "fa-thermometer-full", "Caliente"),
                                            CotizacionMVC.Models.Enums.EstadoCliente.Cerrado => ("success", "fa-check-circle", "Convertido"),
                                            _ => ("secondary", "fa-circle", "Sin Contactar")
                                        };

                                        <tr>
                                            <td class="ps-4">
                                                <strong>@lead.NombreContacto</strong>
                                                <br><small class="text-muted">@lead.Telefono</small>
                                            </td>
                                            <td><small>@lead.EmpresaNombre</small></td>
                                            <td><span class="badge bg-light text-dark">@(lead.ProductoBusca ?? "Sin producto")</span></td>
                                            <td class="text-center">
                                                <span class="badge rounded-pill bg-@tempColor bg-opacity-10 text-@tempColor px-3 py-2">
                                                    <i class="fas @tempIcono me-1"></i>@tempTexto
                                                </span>
                                            </td>
                                            <td><small class="text-muted">@lead.FechaCreacion.ToString("dd MMM")</small></td>
                                            <td class="text-center">
                                                <a asp-action="Crear" asp-route-leadId="@lead.Id" class="btn btn-sm btn-outline-danger" title="Cotizar">
                                                    <i class="fas fa-plus-circle me-1"></i>Cotizar
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ========== COTIZACIONES ========== *@
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom d-flex flex-wrap justify-content-between align-items-center py-3 gap-2">
            <h6 class="mb-0 fw-bold">Cotizaciones <span class="badge bg-danger ms-2">@total</span></h6>
            <div class="input-group input-group-sm" style="width:220px;">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted small"></i></span>
                <input type="text" class="form-control border-start-0" placeholder="Buscar..." id="buscarCotizacion">
            </div>
        </div>
        <div class="card-body p-0">
            @if (!cotizaciones.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-file-invoice fa-3x mb-3 opacity-25"></i>
                    <p class="mb-2">No hay cotizaciones registradas</p>
                    <a asp-action="Crear" class="btn btn-danger btn-sm">Nueva Cotización</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="tablaCotizaciones">
                        <thead class="table-light small text-uppercase text-muted">
                            <tr>
                                <th class="ps-4">Folio</th>
                                <th>Cliente</th>
                                <th>Empresa</th>
                                <th>Fecha</th>
                                <th class="text-end">Total</th>
                                <th class="text-center">Estado</th>
                                <th class="text-center" style="width:120px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cotizacion in cotizaciones)
                            {
                                var (colorBadge, iconoEstado, textoEstado) = cotizacion.Estado switch
                                {
                                    CotizacionMVC.Models.Enums.EstadoCotizacion.InformacionSolicitada => ("info", "fa-search", "Info. Solicitada"),
                                    CotizacionMVC.Models.Enums.EstadoCotizacion.CotizacionEnviada => ("primary", "fa-paper-plane", "Enviada"),
                                    CotizacionMVC.Models.Enums.EstadoCotizacion.PreguntaInstalacion => ("warning", "fa-tools", "Consulta Inst."),
                                    CotizacionMVC.Models.Enums.EstadoCotizacion.NegociandoPrecio => ("warning", "fa-comments-dollar", "Negociando"),
                                    CotizacionMVC.Models.Enums.EstadoCotizacion.FechaTentativa => ("info", "fa-calendar-check", "Fecha Tent."),
                                    CotizacionMVC.Models.Enums.EstadoCotizacion.Aceptada => ("success", "fa-check-circle", "Aceptada"),
                                    CotizacionMVC.Models.Enums.EstadoCotizacion.PagoAnticipo => ("success", "fa-money-bill-wave", "Pago Ant."),
                                    CotizacionMVC.Models.Enums.EstadoCotizacion.Cerrada => ("dark", "fa-check-double", "Cerrada"),
                                    CotizacionMVC.Models.Enums.EstadoCotizacion.Perdida => ("danger", "fa-times-circle", "Perdida"),
                                    _ => ("secondary", "fa-circle", cotizacion.Estado.ToString())
                                };

                                <tr>
                                    <td class="ps-4"><span class="badge bg-light text-dark fw-bold">@cotizacion.NumeroCotizacion</span></td>
                                    <td><strong>@cotizacion.ClienteNombre</strong></td>
                                    <td><small class="text-muted">@cotizacion.EmpresaNombre</small></td>
                                    <td><small class="text-muted">@cotizacion.FechaCreacion.ToLocalTime().ToString("dd MMM yyyy")</small></td>
                                    <td class="text-end"><strong>@cotizacion.Total.ToString("N0") <small class="text-muted">@cotizacion.Moneda</small></strong></td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-@colorBadge bg-opacity-10 text-@colorBadge px-3 py-2">
                                            <i class="fas @iconoEstado me-1"></i>@textoEstado
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <a asp-action="Detalles" asp-route-id="@cotizacion.Id" class="btn btn-sm btn-outline-secondary" title="Ver">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="DescargarPdf" asp-route-id="@cotizacion.Id" class="btn btn-sm btn-outline-danger" title="PDF">
                                                <i class="fas fa-file-pdf"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        @if (cotizaciones.Any())
        {
            <div class="card-footer bg-white d-flex justify-content-between align-items-center small text-muted">
                <span><i class="fas fa-sync-alt me-1"></i>Actualizado: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                <span>@total cotizaciones</span>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .card { transition: box-shadow 0.2s; }
        .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08) !important; }
        .table-hover tbody tr:hover { background-color: rgba(0,0,0,0.015); }
        .nav-tabs .nav-link {
            color: #6c757d;
            border: none;
            border-bottom: 2px solid transparent;
            font-weight: 500;
            font-size: 0.9rem;
        }
        .nav-tabs .nav-link.active {
            color: #C8102E;
            border-bottom: 2px solid #C8102E;
            background: transparent;
        }
        .nav-tabs .nav-link:hover:not(.active) {
            border-bottom-color: #dee2e6;
        }
        .badge[class*="bg-opacity-10"] {
            font-weight: 500;
        }
    </style>
}

@section Scripts {
    <script>
        document.getElementById('buscarCotizacion').addEventListener('keyup', function() {
            var value = this.value.toLowerCase();
            document.querySelectorAll('#tablaCotizaciones tbody tr').forEach(function(row) {
                row.style.display = row.textContent.toLowerCase().includes(value) ? '' : 'none';
            });
        });
    </script>
}