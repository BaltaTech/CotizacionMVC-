@model CotizacionMVC.Models.Entidades.Cotizacion

@{
    ViewData["Title"] = "Editar Cotización";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                <i class="fas fa-edit"></i> Editar Cotización: @Model.NumeroCotizacion
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="Editar" method="post" id="formEditar">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />

                <!-- Datos básicos -->
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label for="clienteId" class="form-label fw-bold">Cliente <span class="text-danger">*</span></label>
                            <select id="clienteId" name="clienteId" class="form-select" required>
                                <option value="">Seleccione un cliente</option>
                                @foreach (var cliente in ViewBag.Clientes)
                                {
                                    if (cliente.Id == Model.ClienteId)
                                    {
                                        <option value="@cliente.Id" selected>@cliente.Nombre</option>
                                    }
                                    else
                                    {
                                        <option value="@cliente.Id">@cliente.Nombre</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label for="areaMetrosCuadrados" class="form-label fw-bold">Área (m²) <span class="text-danger">*</span></label>
                            <input type="number" id="areaMetrosCuadrados" name="areaMetrosCuadrados"
                                   class="form-control" step="0.01" min="0"
                                   value="@Model.AreaMetrosCuadrados.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                   required />
                            <small class="text-muted">Ingrese los metros cuadrados del proyecto</small>
                        </div>
                    </div>
                </div>

                <!-- Condiciones de pago -->
                <div class="form-group mb-3">
                    <label for="condicionesPago" class="form-label fw-bold">Condiciones de Pago</label>
                    <textarea id="condicionesPago" name="condicionesPago" class="form-control" rows="3">@Model.CondicionesPago</textarea>
                    <small class="text-muted">Ej: 50% anticipo, 50% contra entrega</small>
                </div>

                <!-- Resumen de equipos -->
                <div class="row mt-4">
                    <div class="col-md-6">
                        <h5 class="text-primary"><i class="fas fa-microchip"></i> Equipos Cotizados</h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Cant.</th>
                                        <th>Equipo</th>
                                        <th>P. Unitario</th>
                                        <th>Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.ItemsEquipos != null && Model.ItemsEquipos.Any())
                                    {
                                        foreach (var item in Model.ItemsEquipos)
                                        {
                                            <tr>
                                                <td>@item.Cantidad</td>
                                                <td>
                                                    @if (item.Equipo != null)
                                                    {
                                                        <span>@item.Equipo.Marca @item.Equipo.Modelo</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Equipo no disponible</span>
                                                    }
                                                </td>
                                                <td>@item.PrecioUnitario.Monto.ToString("N2")</td>
                                                <td class="fw-bold">@item.Subtotal.Monto.ToString("N2")</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted">No hay equipos registrados</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Resumen de instalaciones -->
                    <div class="col-md-6">
                        <h5 class="text-primary"><i class="fas fa-tools"></i> Instalaciones</h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Concepto</th>
                                        <th>Cant.</th>
                                        <th>Costo Unit.</th>
                                        <th>Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.ItemsInstalacion != null && Model.ItemsInstalacion.Any())
                                    {
                                        foreach (var item in Model.ItemsInstalacion)
                                        {
                                            <tr>
                                                <td>@item.Concepto</td>
                                                <td>@item.Cantidad</td>

                                                <td class="fw-bold">@item.Subtotal.Monto.ToString("N2")</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted">No hay instalaciones registradas</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Totales -->
                <div class="row mt-3">
                    <div class="col-md-6 offset-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold">Subtotal:</span>
                                    <span>@Model.Subtotal.Monto.ToString("N2")</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold">IVA (16%):</span>
                                    <span>@Model.Iva.Monto.ToString("N2")</span>
                                </div>
                                <hr />
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold fs-5">Total:</span>
                                    <span class="fw-bold fs-5 text-primary">@Model.Total.Monto.ToString("N2")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

               

                <!-- Botones de acción -->
                <div class="row mt-4">
                    <div class="col-12">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                        <a asp-action="Detalles" asp-route-id="@Model.Id" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Cancelar
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Validación del formulario
        document.getElementById('formEditar').addEventListener('submit', function(e) {
            var clienteId = document.getElementById('clienteId').value;
            var area = document.getElementById('areaMetrosCuadrados').value;

            if (!clienteId) {
                e.preventDefault();
                alert('Por favor, seleccione un cliente');
                return false;
            }

            if (!area || parseFloat(area) <= 0) {
                e.preventDefault();
                alert('Por favor, ingrese un área válida mayor a 0');
                return false;
            }

            return true;
        });

        // Validación de área en tiempo real
        document.getElementById('areaMetrosCuadrados').addEventListener('input', function() {
            if (this.value < 0) {
                this.value = 0;
            }
        });
    </script>
}