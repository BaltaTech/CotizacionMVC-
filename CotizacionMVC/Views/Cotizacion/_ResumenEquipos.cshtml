@{
    var equipos = ViewBag.Equipos as List<dynamic> ?? new List<dynamic>();
}

<table class="table table-striped" id="tablaEquipos">
    <thead class="table-secondary">
        <tr>
            <th>Marca</th>
            <th>Modelo</th>
            <th>Capacidad</th>
            <th>Cantidad</th>
            <th>Precio Unitario</th>
            <th>Subtotal</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (equipos.Any())
        {
            for (int i = 0; i < equipos.Count; i++)
            {
                var eq = equipos[i];
                <tr>
                    <td><span class="badge bg-info">@eq.Marca</span></td>
                    <td>@eq.Modelo</td>
                    <td>@eq.Capacidad</td>
                    <td>
                        <input type="number" class="form-control form-control-sm cantidad-equipo" style="width:80px" data-indice="@i" value="@eq.Cantidad" min="1" />
                    </td>
                    <td>$@eq.PrecioUnitario.ToString("N2")</td>
                    <td>$@eq.Subtotal.ToString("N2")</td>
                    <td>
                        <button type="button" class="btn btn-sm btn-danger eliminar-equipo" data-indice="@i">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted">No hay equipos agregados</td>
            </tr>
        }
    </tbody>
</table>

<script>
    $(document).ready(function() {
        $('.cantidad-equipo').off('change').on('change', function() {
            var indice = $(this).data('indice');
            var cantidad = $(this).val();
            $.post('/Cotizacion/ActualizarCantidadEquipo', { indice: indice, cantidad: cantidad }, function(data) {
                if (data.success) {
                    $('#equiposContainer').html(data.html);
                }
            });
        });

        $('.eliminar-equipo').off('click').on('click', function() {
            var indice = $(this).data('indice');
            $.post('/Cotizacion/EliminarEquipo', { indice: indice }, function(data) {
                if (data.success) {
                    $('#equiposContainer').html(data.html);
                }
            });
        });
    });
</script>