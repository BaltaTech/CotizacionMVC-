@model CotizacionMVC.Models.Entidades.Cotizacion

@{
    ViewData["Title"] = $"Cotización {Model.NumeroCotizacion}";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2><i class="fas fa-file-invoice"></i> Cotización @Model.NumeroCotizacion</h2>
        </div>
        <div class="card-body">
            <!-- Datos de la cotización -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <h5 class="text-primary">Cliente</h5>
                    <p><strong>@Model.Cliente?.Nombre</strong></p>
                    @if (!string.IsNullOrWhiteSpace(Model.Cliente?.Contacto?.NombreContacto))
                    {
                        <p><small>Attn: @Model.Cliente.Contacto.NombreContacto</small></p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Cliente?.Contacto?.Telefono))
                    {
                        <p><i class="fas fa-phone"></i> @Model.Cliente.Contacto.Telefono</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Cliente?.Contacto?.Correo))
                    {
                        <p><i class="fas fa-envelope"></i> @Model.Cliente.Contacto.Correo</p>
                    }
                </div>
                <div class="col-md-6">
                    <h5 class="text-primary">Datos de la Cotización</h5>
                    <p><strong>Empresa:</strong> @Model.Empresa?.NombreComercial</p>
                    <p><strong>Vendedor:</strong> @Model.Vendedor?.NombreCompleto</p>
                    <p><strong>Fecha:</strong> @Model.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Válida hasta:</strong> @Model.FechaVencimiento.ToLocalTime().ToString("dd/MM/yyyy")</p>
                    @if (!string.IsNullOrWhiteSpace(Model.CondicionesPago))
                    {
                        <p><strong>Condiciones de pago:</strong> @Model.CondicionesPago</p>
                    }
                </div>
            </div>

            <!-- Equipos -->
            <h4 class="text-primary mt-4"><i class="fas fa-microchip"></i> Equipos</h4>
            @if (Model.ItemsEquipos.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead class="table-secondary">
                            <tr>
                                <th>Marca</th>
                                <th>Modelo</th>
                                <th>Capacidad</th>
                                <th>Cantidad</th>
                                <th>Precio Unitario</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ItemsEquipos)
                            {
                                <tr>
                                    <td><span class="badge bg-info">@item.Equipo?.Marca</span></td>
                                    <td>@item.Equipo?.Modelo</td>
                                    <td>@item.Equipo?.CapacidadToneladas TR</td>
                                    <td>@item.Cantidad</td>
                                    <td>@item.PrecioUnitario.ToString()</td>
                                    <td>@item.Subtotal.ToString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No hay equipos en esta cotización.</p>
            }

            <!-- Instalaciones -->
            <h4 class="text-primary mt-4"><i class="fas fa-tools"></i> Instalaciones</h4>
            @if (Model.ItemsInstalacion.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead class="table-secondary">
                            <tr>
                                <th>Concepto</th>
                                <th>Descripción</th>
                                <th>Cantidad</th>
                                <th>Costo Unitario</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ItemsInstalacion)
                            {
                                <tr>
                                    <td>@item.Concepto</td>
                                    <td>@item.Descripcion</td>
                                    <td>@item.Cantidad</td>
                                    <td>@item.CostoUnitario.ToString()</td>
                                    <td>@item.Subtotal.ToString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No hay instalaciones en esta cotización.</p>
            }

            <!-- Totales -->
            <div class="row mt-4">
                <div class="col-md-6 offset-md-6">
                    <div class="card bg-light">
                        <div class="card-body">
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>Subtotal:</strong></td>
                                    <td class="text-end">@Model.Subtotal.ToString()</td>
                                </tr>
                                <tr>
                                    <td><strong>IVA (16%):</strong></td>
                                    <td class="text-end">@Model.Iva.ToString()</td>
                                </tr>
                                <tr class="table-primary">
                                    <td><strong>TOTAL:</strong></td>
                                    <td class="text-end fw-bold fs-5">@Model.Total.ToString()</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Estado actual -->
            <div class="mt-4">
                <h5>Estado actual: <span class="badge bg-secondary">@Model.ObtenerPorcentajeEstado()% - @Model.Estado</span></h5>
            </div>
        </div>
        <div class="card-footer">
            <a asp-action="Indice" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver al listado
            </a>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
}