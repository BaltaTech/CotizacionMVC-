@model CotizacionMVC.ViewModels.Cotizacion.CotizacionDetalleViewModel

@{
    ViewData["Title"] = $"Cotización {Model.NumeroCotizacion}";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2><i class="fas fa-file-invoice"></i> Cotización @Model.NumeroCotizacion</h2>
        </div>
        <div class="card-body">

            <!-- Datos de la cotización -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <h5 class="text-primary">Cliente</h5>
                    <p><strong>@Model.ClienteNombre</strong></p>
                </div>
                <div class="col-md-6">
                    <h5 class="text-primary">Datos de la Cotización</h5>
                    <p><strong>Empresa:</strong> @Model.EmpresaNombre</p>
                    <p><strong>Vendedor:</strong> @Model.VendedorNombre</p>
                    <p><strong>Fecha:</strong> @Model.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Válida hasta:</strong> @Model.FechaVencimiento.ToLocalTime().ToString("dd/MM/yyyy")</p>
                    @if (!string.IsNullOrWhiteSpace(Model.CondicionesPago))
                    {
                        <p><strong>Condiciones de pago:</strong> @Model.CondicionesPago</p>
                    }
                </div>
            </div>

            <!-- Equipos -->
            <h4 class="text-primary mt-4"><i class="fas fa-microchip"></i> Equipos</h4>
            @if (Model.Equipos.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead class="table-secondary">
                            <tr>
                                <th>Marca</th>
                                <th>Modelo</th>
                                <th>Cantidad</th>
                                <th>Precio Unitario</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Equipos)
                            {
                                <tr>
                                    <td><span class="badge bg-info">@item.EquipoMarca</span></td>
                                    <td>@item.EquipoModelo</td>
                                    <td>@item.Cantidad</td>
                                    <td>@item.PrecioUnitario.ToString("N2")</td>
                                    <td>@item.Subtotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No hay equipos en esta cotización.</p>
            }

            <!-- Instalaciones -->
            <h4 class="text-primary mt-4"><i class="fas fa-tools"></i> Instalaciones</h4>
            @if (Model.Instalaciones.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead class="table-secondary">
                            <tr>
                                <th>Concepto</th>
                                <th>Descripción</th>
                                <th>Cantidad</th>
                                <th>Costo Unitario</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Instalaciones)
                            {
                                <tr>
                                    <td>@item.Concepto</td>
                                    <td>@item.Descripcion</td>
                                    <td>@item.Cantidad</td>
                                    <td>@item.CostoUnitario.ToString("N2")</td>
                                    <td>@item.Subtotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No hay instalaciones en esta cotización.</p>
            }

            <!-- Totales -->
            <div class="row mt-4">
                <div class="col-md-6 offset-md-6">
                    <div class="card bg-light">
                        <div class="card-body">
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>Subtotal:</strong></td>
                                    <td class="text-end">@Model.Subtotal.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td><strong>IVA (16%):</strong></td>
                                    <td class="text-end">@Model.Iva.ToString("N2")</td>
                                </tr>
                                <tr class="table-primary">
                                    <td><strong>TOTAL:</strong></td>
                                    <td class="text-end fw-bold fs-5">@Model.Total.ToString("N2") @Model.Moneda</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Estado actual -->
            <div class="mt-4">
                <h5>Estado actual: <span class="badge bg-secondary">@Model.Estado</span></h5>
            </div>
        </div>
        <div class="card-footer">
            <a asp-action="Indice" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver al listado
            </a>
            <a asp-action="DescargarPdf" asp-route-id="@Model.Id" class="btn btn-danger">
                <i class="fas fa-file-pdf"></i> Descargar PDF
            </a>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
}