@{
    var instalaciones = ViewBag.Instalaciones as List<dynamic> ?? new List<dynamic>();
}

<table class="table table-striped" id="tablaInstalaciones">
    <thead class="table-secondary">
        <tr>
            <th>Concepto</th>
            <th>Descripción</th>
            <th>Cantidad</th>
            <th>Costo Unitario</th>
            <th>Subtotal</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (instalaciones.Any())
        {
            for (int i = 0; i < instalaciones.Count; i++)
            {
                var inst = instalaciones[i];
                <tr>
                    <td>@inst.Concepto</td
                    <td>@inst.Descripcion</td
                    <td>
                        <input type="number" class="form-control form-control-sm cantidad-instalacion" style="width:80px" data-indice="@i" value="@inst.Cantidad" min="1" />
                    </td
                    <td>$@inst.CostoUnitario.ToString("N2")</td
                    <td>$@inst.Subtotal.ToString("N2")</td
                    <td>
                        <button type="button" class="btn btn-sm btn-danger eliminar-instalacion" data-indice="@i">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No hay instalaciones agregadas</td
            </tr>
        }
    </tbody>
</table>

<script>
    $(document).ready(function() {
        $('.cantidad-instalacion').off('change').on('change', function() {
            var indice = $(this).data('indice');
            var cantidad = $(this).val();
            $.post('/Cotizacion/ActualizarCantidadInstalacion', { indice: indice, cantidad: cantidad }, function(data) {
                if (data.success) {
                    $('#instalacionesContainer').html(data.html);
                }
            });
        });

        $('.eliminar-instalacion').off('click').on('click', function() {
            var indice = $(this).data('indice');
            $.post('/Cotizacion/EliminarInstalacion', { indice: indice }, function(data) {
                if (data.success) {
                    $('#instalacionesContainer').html(data.html);
                }
            });
        });
    });
</script>