@* Views/Seguimiento/Dashboard.cshtml *@
@{
    ViewData["Title"] = "Panel de Seguimiento";
    var vendedorId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="dashboard-container">
    <div class="dash-header">
        <div>
            <h1><i class="fas fa-chart-line"></i> Panel de Seguimiento</h1>
            <span id="fechaActual" class="text-muted"></span>
        </div>
        <div class="dash-actions">
            <a asp-action="CrearLead" class="btn btn-sm btn-warning">
                <i class="fas fa-lightbulb"></i> Nuevo Lead
            </a>
            <a asp-action="Indice" asp-controller="Cotizacion" class="btn btn-sm btn-primary">
                <i class="fas fa-list"></i> Leads y Cotizaciones
            </a>
        </div>
    </div>

    <div class="metrics-row">
        <div class="metric-card metric-red">
            <div class="metric-icon"><i class="fas fa-headset"></i></div>
            <div class="metric-data">
                <span class="metric-label">Recep. sin contactar</span>
                <span class="metric-value" id="vRecepcionSinContactar">--</span>
            </div>
        </div>
        <div class="metric-card metric-orange">
            <div class="metric-icon"><i class="fas fa-search"></i></div>
            <div class="metric-data">
                <span class="metric-label">Prosp. sin contactar</span>
                <span class="metric-value" id="vProspeccionSinContactar">--</span>
            </div>
        </div>
        <div class="metric-card metric-blue">
            <div class="metric-icon"><i class="fas fa-file-invoice"></i></div>
            <div class="metric-data">
                <span class="metric-label">Cotizaciones Activas</span>
                <span class="metric-value" id="vActivas">--</span>
            </div>
        </div>
        <div class="metric-card metric-green">
            <div class="metric-icon"><i class="fas fa-check-circle"></i></div>
            <div class="metric-data">
                <span class="metric-label">Realizados Hoy</span>
                <span class="metric-value" id="vRealizados">--</span>
            </div>
        </div>
        <div class="metric-card metric-purple">
            <div class="metric-icon"><i class="fas fa-dollar-sign"></i></div>
            <div class="metric-data">
                <span class="metric-label">Vendido este mes</span>
                <span class="metric-value" id="vVendidoMes">--</span>
            </div>
        </div>
    </div>

    <div class="dash-section">
        <div class="dash-section-header">
            <h3><i class="fas fa-tasks"></i> Seguimientos Pendientes Hoy</h3>
        </div>
        <div class="table-responsive">
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Cliente/Lead</th>
                        <th>Etapa</th>
                        <th>Medio</th>
                        <th>Contacto</th>
                        <th>Notas</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody id="tablaPendientes">
                    <tr><td colspan="6" class="text-center text-muted py-3">Cargando seguimientos...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="dash-section mt-3">
        <div class="dash-section-header">
            <h3><i class="fas fa-history"></i> Últimos Seguimientos</h3>
        </div>
        <div id="ultimosSeguimientos">
            <p class="text-muted text-center py-3">Cargando...</p>
        </div>
    </div>
</div>

<style>
    .dashboard-container { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }
    .dash-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 2px solid #f0f0f0; }
    .dash-header h1 { font-size: 1.4rem; font-weight: 700; color: #1a1a1a; margin: 0; }
    .dash-header span { font-size: 0.8rem; }
    .dash-actions { display: flex; gap: 0.5rem; }
    .metrics-row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
    .metric-card { background: #fff; border-radius: 10px; padding: 1.25rem; display: flex; align-items: center; gap: 1rem; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: transform 0.2s; }
    .metric-card:hover { transform: translateY(-2px); }
    .metric-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; color: #fff; }
    .metric-red .metric-icon { background: linear-gradient(135deg, #C8102E, #E63946); }
    .metric-orange .metric-icon { background: linear-gradient(135deg, #FF6B35, #F7931E); }
    .metric-blue .metric-icon { background: linear-gradient(135deg, #1A73E8, #4285F4); }
    .metric-green .metric-icon { background: linear-gradient(135deg, #28a745, #20c997); }
    .metric-purple .metric-icon { background: linear-gradient(135deg, #6f42c1, #8b5cf6); }
    .metric-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; color: #888; display: block; }
    .metric-value { font-size: 1.6rem; font-weight: 700; color: #1a1a1a; line-height: 1.2; }
    .dash-section { background: #fff; border-radius: 10px; padding: 1.25rem; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .dash-section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid #f0f0f0; }
    .dash-section-header h3 { font-size: 1rem; font-weight: 600; margin: 0; }
    .dash-table { width: 100%; font-size: 0.85rem; }
    .dash-table th { background: #f8f9fa; padding: 0.7rem; text-align: left; font-weight: 600; color: #555; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .dash-table td { padding: 0.7rem; border-bottom: 1px solid #f5f5f5; vertical-align: middle; }
    .dash-table tr:hover { background: #fafafa; }
    .badge-estado { padding: 0.25rem 0.6rem; border-radius: 20px; font-size: 0.7rem; font-weight: 500; }
    .badge-pendiente { background: #fff3cd; color: #856404; }
    .badge-urgente { background: #f8d7da; color: #721c24; }
    .badge-exito { background: #d4edda; color: #155724; }
    .badge-info { background: #d1ecf1; color: #0c5460; }
    .btn-accion { padding: 0.25rem 0.6rem; font-size: 0.75rem; border-radius: 4px; text-decoration: none; color: #fff; background: #1A73E8; }
    .btn-accion:hover { background: #1557b0; color: #fff; }
</style>

@section Scripts {
    <script>
        document.getElementById('fechaActual').textContent =
            new Date().toLocaleDateString('es-MX', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

        function cargarDashboard() {
            fetch('/Seguimiento/MiDashboard')
                .then(r => r.json())
                .then(d => {
                    document.getElementById('vRecepcionSinContactar').textContent = d.recepcionSinContactar || 0;
                    document.getElementById('vProspeccionSinContactar').textContent = d.prospeccionSinContactar || 0;
                    document.getElementById('vActivas').textContent = d.cotizacionesActivas || 0;
                    document.getElementById('vRealizados').textContent = d.seguimientosRealizadosHoy || 0;
                    document.getElementById('vVendidoMes').textContent = d.montoVendidoMes ? '$' + d.montoVendidoMes.toLocaleString() : '$0';

                    if (d.proximosSeguimientos && d.proximosSeguimientos.length) {
                        var html = '';
                        d.proximosSeguimientos.forEach(function(s) {
                            var etapaBadge = s.etapaNegociacion 
                                ? '<span class="badge-estado badge-exito">' + s.etapaNegociacion + '</span>'
                                : '<span class="badge-estado badge-pendiente">Pendiente</span>';
                            html += `<tr>
                                <td><strong>${s.leadNombre || s.cotizacionNumero || 'Sin referencia'}</strong></td>
                                <td>${etapaBadge}</td>
                                <td><span class="badge-estado badge-info">${s.medioContacto || 'Pendiente'}</span></td>
                                <td>${s.telefono || s.correoElectronico || 'Sin contacto'}</td>
                                <td><small>${s.notas || 'Sin notas'}</small></td>
                                <td>
                                    <a href="/Seguimiento/Crear?leadId=${s.leadId || ''}&cotizacionId=${s.cotizacionId || ''}" 
                                       class="btn-accion">
                                        <i class="fas fa-check"></i> Registrar
                                    </a>
                                </td>
                            </tr>`;
                        });
                        document.getElementById('tablaPendientes').innerHTML = html;
                    } else {
                        document.getElementById('tablaPendientes').innerHTML =
                            '<tr><td colspan="6" class="text-center text-muted py-3">¡Sin seguimientos pendientes! 🎉</td></tr>';
                    }
                })
                .catch(err => { console.error('Error al cargar dashboard:', err); });
        }

        function cargarUltimosSeguimientos() {
            fetch('/Seguimiento/PorVendedor?vendedorId=@vendedorId')
                .then(r => r.text())
                .then(html => { document.getElementById('ultimosSeguimientos').innerHTML = html; })
                .catch(err => {
                    document.getElementById('ultimosSeguimientos').innerHTML = 
                        '<p class="text-muted text-center py-3">Error al cargar</p>';
                });
        }

        cargarDashboard();
        cargarUltimosSeguimientos();
        setInterval(cargarDashboard, 60000);
    </script>
}