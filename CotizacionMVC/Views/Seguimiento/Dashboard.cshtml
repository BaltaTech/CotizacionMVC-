@* Views/Seguimiento/Dashboard.cshtml *@
@{
    ViewData["Title"] = "Panel de Ventas";
    var vendedorId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="sales-dashboard">
    <div class="sd-topbar">
        <div>
            <h1>Panel de Ventas</h1>
            <span id="fechaActual"></span>
        </div>
        <a asp-controller="Seguimiento" asp-action="CrearLead" class="sd-btn sd-btn-outline">+ Nuevo Lead</a>
    </div>

    <div class="sd-grid">
        <div class="sd-card sd-card-red">
            <p class="sd-card-label">Sin contactar</p>
            <h3 class="sd-card-value" id="vSinContactar">--</h3>
            <i class="fas fa-user-clock sd-card-icon"></i>
        </div>
        <div class="sd-card sd-card-orange">
            <p class="sd-card-label">Frías +15 días</p>
            <h3 class="sd-card-value" id="vFrias">--</h3>
            <i class="fas fa-snowflake sd-card-icon"></i>
        </div>
        <div class="sd-card sd-card-blue">
            <p class="sd-card-label">Pendientes hoy</p>
            <h3 class="sd-card-value" id="vPendientes">--</h3>
            <i class="fas fa-calendar-check sd-card-icon"></i>
        </div>
        <div class="sd-card sd-card-green">
            <p class="sd-card-label">Realizados hoy</p>
            <h3 class="sd-card-value" id="vRealizados">--</h3>
            <i class="fas fa-check-circle sd-card-icon"></i>
        </div>
    </div>

    <div class="sd-row">
        <div class="sd-card sd-card-white">
            <p class="sd-card-label">Cotizaciones activas</p>
            <h3 id="vActivas">--</h3>
        </div>
        <div class="sd-card sd-card-white">
            <p class="sd-card-label">Calificados sin cotizar</p>
            <h3 id="vCalificados">--</h3>
        </div>
        <div class="sd-card sd-card-white sd-card-alert">
            <p class="sd-card-label">Vencidos</p>
            <h3 id="vVencidos">--</h3>
        </div>
    </div>

    <div class="sd-section" id="sdAgenda" style="display:none;">
        <h4>Próximos seguimientos para hoy</h4>
        <div id="sdAgendaContent"></div>
    </div>
</div>

<style>
    .sales-dashboard {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }
    .sd-topbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e9ecef;
    }
    .sd-topbar h1 {
        font-size: 1.5rem;
        font-weight: 600;
        color: #1a1a1a;
        margin: 0;
    }
    .sd-topbar span {
        font-size: 0.8rem;
        color: #6c757d;
    }
    .sd-btn {
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
        border: none;
    }
    .sd-btn-outline {
        border: 1px solid #C8102E;
        color: #C8102E;
        background: #fff;
    }
    .sd-btn-outline:hover {
        background: #C8102E;
        color: #fff;
    }

    .sd-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .sd-card {
        border-radius: 8px;
        padding: 1.25rem;
        position: relative;
        overflow: hidden;
    }
    .sd-card-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin: 0 0 0.5rem 0;
        opacity: 0.8;
    }
    .sd-card-value {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
        line-height: 1;
    }
    .sd-card-icon {
        position: absolute;
        right: 1rem;
        bottom: -0.5rem;
        font-size: 3rem;
        opacity: 0.1;
    }
    .sd-card-red {
        background: #C8102E;
        color: #fff;
    }
    .sd-card-orange {
        background: #f7931e;
        color: #fff;
    }
    .sd-card-blue {
        background: #1A73E8;
        color: #fff;
    }
    .sd-card-green {
        background: #28a745;
        color: #fff;
    }
    .sd-card-white {
        background: #fff;
        border: 1px solid #e9ecef;
    }
    .sd-card-white .sd-card-value {
        color: #1a1a1a;
        font-size: 1.3rem;
    }
    .sd-card-alert .sd-card-value {
        color: #C8102E;
    }

    .sd-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .sd-section {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 1.25rem;
    }
    .sd-section h4 {
        font-size: 0.85rem;
        font-weight: 600;
        color: #1a1a1a;
        margin: 0 0 1rem 0;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #e9ecef;
    }
    .sd-agenda-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.6rem 0;
        border-bottom: 1px solid #f8f9fa;
    }
    .sd-agenda-item:last-child { border-bottom: none; }
    .sd-agenda-item strong { font-size: 0.85rem; }
    .sd-agenda-badge {
        background: #C8102E;
        color: #fff;
        padding: 0.15rem 0.5rem;
        border-radius: 12px;
        font-size: 0.7rem;
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const vendedorId = '@vendedorId';
        document.getElementById('fechaActual').textContent =
            new Date().toLocaleDateString('es-MX', { weekday: 'long', day: 'numeric', month: 'long' });

        function cargar() {
            fetch('/Seguimiento/MiDashboard')
                .then(r => r.json())
                .then(d => {
                    document.getElementById('vSinContactar').textContent = d.leadsSinContactar;
                    document.getElementById('vFrias').textContent = d.leadsFriosSinActividad;
                    document.getElementById('vPendientes').textContent = d.seguimientosPendientesHoy;
                    document.getElementById('vRealizados').textContent = d.seguimientosRealizadosHoy;
                    document.getElementById('vActivas').textContent = d.cotizacionesActivas;
                    document.getElementById('vCalificados').textContent = d.leadsCalificadosSinCotizar;
                    document.getElementById('vVencidos').textContent = d.seguimientosVencidos;

                    if (d.proximosSeguimientos && d.proximosSeguimientos.length) {
                        document.getElementById('sdAgenda').style.display = 'block';
                        document.getElementById('sdAgendaContent').innerHTML = d.proximosSeguimientos.map(s =>
                            `<div class="sd-agenda-item">
                                <div><strong>${s.leadNombre || s.cotizacionNumero || 'Sin ref'}</strong>
                                <small class="text-muted d-block">${s.notas || ''}</small></div>
                                <span class="sd-agenda-badge">${s.medioContacto}</span>
                            </div>`
                        ).join('');
                    }
                });
        }

        function conectarSignalR() {
            if (typeof connection !== 'undefined' && connection.state === 'Connected') {
                connection.on("ActualizarDashboard", cargar);
                connection.invoke("UnirseAGrupo", vendedorId);
            } else { setTimeout(conectarSignalR, 1000); }
        }

        setTimeout(conectarSignalR, 1000);
        cargar();
        setInterval(cargar, 300000);
    </script>
}