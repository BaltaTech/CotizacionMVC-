@using CotizacionMVC.ViewModels.Seguimientos
@model CrearSeguimientoViewModel
@{
    ViewData["Title"] = Model.EsSeguimientoGeneral ? "Nuevo Seguimiento" : $"Seguimiento de {Model.TipoSeguimiento}";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-journal-plus"></i> @ViewData["Title"]
                    </h5>
                </div>
                <div class="card-body">
                    @if (!Model.EsSeguimientoGeneral)
                    {
                        <div class="card bg-light mb-3 border-start border-3 border-primary">
                            <div class="card-body py-2 px-3">
                                <div class="row">
                                    <div class="col-md-6">
                                        <small class="text-muted">@Model.TipoSeguimiento</small><br>
                                        <strong>@Model.ClienteNombre</strong>
                                    </div>
                                    <div class="col-md-6">
                                        <small class="text-muted">Etapa actual</small><br>
                                        <span class="badge bg-info">@Model.EtapaActual</span>
                                    </div>
                                    @if (Model.TipoSeguimiento == "Lead")
                                    {
                                        <div class="col-md-6 mt-2">
                                            <small class="text-muted">Origen</small><br>
                                            <span>@Model.Origen</span>
                                        </div>
                                        <div class="col-md-6 mt-2">
                                            <small class="text-muted">Contacto</small><br>
                                            <span>@(Model.ClienteTelefono ?? Model.ClienteCorreo ?? "Sin contacto")</span>
                                        </div>
                                    }
                                    @if (Model.TipoSeguimiento == "Cotización")
                                    {
                                        <div class="col-md-6 mt-2">
                                            <small class="text-muted">Folio</small><br>
                                            <span class="badge bg-dark">@Model.NumeroCotizacion</span>
                                        </div>
                                        <div class="col-md-6 mt-2">
                                            <small class="text-muted">Monto</small><br>
                                            <strong>@(Model.MontoCotizacion?.ToString("C") ?? "N/A")</strong>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Referencia))
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-tag"></i> @Model.Referencia
                        </div>
                    }

                    @if (Model.EsSeguimientoGeneral)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-info-circle"></i>
                            Estás registrando un seguimiento general. Puedes asociarlo a un lead o cotización después.
                        </div>
                    }

                    <form asp-action="Crear" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="LeadId" />
                        <input type="hidden" asp-for="CotizacionId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FechaContacto" class="form-label">Fecha de Contacto</label>
                                <input asp-for="FechaContacto" type="datetime-local" class="form-control"
                                       value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                <span asp-validation-for="FechaContacto" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MedioContactoId" class="form-label">Medio de Contacto</label>
                                <select asp-for="MedioContactoId" class="form-select">
                                    <option value="">-- Seleccione --</option>
                                    <option value="1">📞 Teléfono</option>
                                    <option value="2">💬 WhatsApp</option>
                                    <option value="3">✉️ Correo Electrónico</option>
                                    <option value="4">🏠 Visita</option>
                                </select>
                                <span asp-validation-for="MedioContactoId" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="ResultadoId" class="form-label">¿Qué pasó en la llamada?</label>
                                <select asp-for="ResultadoId" class="form-select" id="selectResultado">
                                    <option value="">-- Seleccione --</option>
                                    <option value="1">❌ Sin Respuesta</option>
                                    <option value="2">👎 No Interesado</option>
                                    <option value="3">🔄 Reagendar Llamada</option>
                                    <option value="10">📋 Solicito Información / Visita</option>
                                    <option value="20">📄 Cotización Solicitada / Enviada</option>
                                    <option value="30">💰 Negociando Precio</option>
                                    <option value="40">📅 Fecha Tentativa</option>
                                    <option value="41">📑 Cotización Firmada</option>
                                    <option value="42">💵 Anticipo Recibido</option>
                                    <option value="50">🎉 Cerrada</option>
                                    <option value="0">💔 Perdida</option>
                                </select>
                                <span asp-validation-for="ResultadoId" class="text-danger small"></span>
                            </div>

                            <div class="col-12" id="divEtapaNegociacion" style="display:none;">
                                <label asp-for="EtapaNegociacionId" class="form-label">Etapa de Negociación</label>
                                <select asp-for="EtapaNegociacionId" class="form-select">
                                    <option value="">-- Seleccione --</option>
                                    <option value="5">📞 Contacto Inicial</option>
                                    <option value="10">📋 Información Solicitada</option>
                                    <option value="20">📄 Cotización Enviada</option>
                                    <option value="30">💬 Preguntó por Instalación</option>
                                    <option value="50">💰 Negociando Precio</option>
                                    <option value="70">📅 Fecha Tentativa</option>
                                    <option value="90">📑 Cotización Firmada</option>
                                    <option value="100">💵 Anticipo Recibido</option>
                                    <option value="110">🎉 Cerrada</option>
                                    <option value="-1">💔 Perdida</option>
                                </select>
                                <span asp-validation-for="EtapaNegociacionId" class="text-danger small"></span>
                                <small class="text-muted">¿En qué etapa queda la negociación?</small>
                            </div>

                            <div class="col-12">
                                <label asp-for="Notas" class="form-label">Notas</label>
                                <textarea asp-for="Notas" class="form-control" rows="4"
                                          placeholder="¿Qué se habló? ¿Qué necesita el cliente?"></textarea>
                                <span asp-validation-for="Notas" class="text-danger small"></span>
                                <small class="text-muted">Máximo 500 caracteres</small>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ProximoContacto" class="form-label">
                                    Próximo Contacto <small class="text-muted">(opcional)</small>
                                </label>
                                <input asp-for="ProximoContacto" type="datetime-local" class="form-control" />
                                <span asp-validation-for="ProximoContacto" class="text-danger small"></span>
                                <small class="text-muted">Agenda un recordatorio para el siguiente contacto</small>
                            </div>
                        </div>

                        <div class="mt-4 d-flex justify-content-between">
                            <a href="javascript:history.back()" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg"></i> Registrar Seguimiento
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var input = document.getElementById('FechaContacto');
            if (input && !input.value) {
                var now = new Date();
                var tzOffset = now.getTimezoneOffset();
                var local = new Date(now.getTime() - tzOffset * 60000);
                input.value = local.toISOString().slice(0, 16);
            }

            var selectResultado = document.getElementById('selectResultado');
            var divEtapa = document.getElementById('divEtapaNegociacion');

            function toggleEtapa() {
                var valor = selectResultado.value;
                if (valor === '1' || valor === '2' || valor === '0' || valor === '') {
                    divEtapa.style.display = 'none';
                } else {
                    divEtapa.style.display = 'block';
                }
            }

            selectResultado.addEventListener('change', toggleEtapa);
            toggleEtapa();
        });
    </script>
}