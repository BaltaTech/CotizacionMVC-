@model IReadOnlyList<CotizacionMVC.Servicios.Aplicacion.Dtos.Recepcion.ClienteDashboardDto>

@{
    ViewData["Title"] = "Panel de Recepción";
    var totalClientes = Model.Count;
    var pendientesAsignar = Model.Count(c => c.Estado == "SinAsignar");
    var pendientesCotizar = Model.Count(c => c.Estado == "Asignado" || c.Estado == "Contactado");
    var cotizados = Model.Count(c => c.Estado == "Cotizado");
    var noCotizables = Model.Count(c => c.Estado == "NoCotizable");
}

<div class="container-fluid px-4">
    
    @* ========== CABECERA ========== *@
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded shadow-sm">
                <div>
                    <h4 class="mb-0" style="color: #C8102E;">
                        <i class="fas fa-headset me-2"></i>Panel de Recepción
                    </h4>
                    <small class="text-muted">Registro de clientes entrantes</small>
                </div>
                <a asp-action="Registrar" class="btn btn-danger">
                    <i class="fas fa-plus-circle me-1"></i> Nuevo Cliente
                </a>
            </div>
        </div>
    </div>

    @* ========== TARJETAS DE RESUMEN ========== *@
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #C8102E, #E63946);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-2" style="opacity: 0.8;">Total Clientes</h6>
                            <h1 class="display-4 fw-bold mb-0">@totalClientes</h1>
                        </div>
                        <i class="fas fa-users fa-3x" style="opacity: 0.3;"></i>
                    </div>
                    <small style="opacity: 0.7;">Registrados en el sistema</small>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #FF6B35, #F7931E);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-2" style="opacity: 0.8;">Pendientes Asignar</h6>
                            <h1 class="display-4 fw-bold mb-0">@pendientesAsignar</h1>
                        </div>
                        <i class="fas fa-user-clock fa-3x" style="opacity: 0.3;"></i>
                    </div>
                    <small style="opacity: 0.7;">Sin vendedor asignado</small>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #1A73E8, #4285F4);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-2" style="opacity: 0.8;">Pendientes Cotizar</h6>
                            <h1 class="display-4 fw-bold mb-0">@pendientesCotizar</h1>
                        </div>
                        <i class="fas fa-file-invoice fa-3x" style="opacity: 0.3;"></i>
                    </div>
                    <small style="opacity: 0.7;">Esperando cotización</small>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #343A40, #495057);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-2" style="opacity: 0.8;">No Cotizables</h6>
                            <h1 class="display-4 fw-bold mb-0">@noCotizables</h1>
                        </div>
                        <i class="fas fa-ban fa-3x" style="opacity: 0.3;"></i>
                    </div>
                    <small style="opacity: 0.7;">No se puede cotizar</small>
                </div>
            </div>
        </div>
    </div>

    @* ========== ÚLTIMOS REGISTROS ========== *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
            <div>
                <i class="fas fa-clock me-2" style="color: #C8102E;"></i>
                <strong style="color: #C8102E;">Últimos Registros</strong>
                <span class="badge bg-danger ms-2" id="contadorUltimos">0</span>
            </div>
            <button class="btn btn-sm btn-outline-danger" id="btnRefrescarUltimos" title="Refrescar">
                <i class="fas fa-sync-alt"></i> Refrescar
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="tablaUltimosRegistros">
                    <thead style="background: linear-gradient(135deg, #C8102E, #E63946); color: white;">
                        <tr>
                            <th class="ps-3">Folio</th>
                            <th>Nombre</th>
                            <th>Teléfono</th>
                            <th>Origen</th>
                            <th>Estado</th>
                            <th>Vendedor</th>
                            <th>Fecha</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyUltimosRegistros">
                        <tr>
                            <td colspan="8" class="text-center py-3">
                                <div class="spinner-border text-danger" role="status"></div>
                                <p class="mt-2 text-muted">Cargando últimos registros...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ========== MODAL VER DETALLE ========== *@
    <div class="modal fade" id="modalDetalleCliente" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header" style="background: linear-gradient(135deg, #C8102E, #E63946); color: white;">
                    <h5 class="modal-title"><i class="fas fa-user-circle me-2"></i>Detalle del Cliente</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="modalDetalleContenido">
                    <div class="text-center py-4"><div class="spinner-border text-danger"></div><p class="mt-2">Cargando...</p></div>
                </div>
            </div>
        </div>
    </div>

    @* ========== MODAL ASIGNAR VENDEDOR ========== *@
    <div class="modal fade" id="modalAsignarVendedor" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header" style="background: linear-gradient(135deg, #FF6B35, #F7931E); color: white;">
                    <h5 class="modal-title"><i class="fas fa-user-plus me-2"></i>Asignar Vendedor</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form id="formAsignarVendedor">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="clienteIdAsignar" name="clienteId" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Cliente</label>
                            <input type="text" class="form-control" id="nombreClienteAsignar" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Vendedor *</label>
                            <select id="vendedorId" name="vendedorId" class="form-select" required>
                                <option value="">-- Seleccione un vendedor --</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-warning"><i class="fas fa-check-circle me-1"></i> Asignar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* ========== MODAL NO COTIZABLE ========== *@
    <div class="modal fade" id="modalNoCotizable" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header" style="background: linear-gradient(135deg, #343A40, #495057); color: white;">
                    <h5 class="modal-title"><i class="fas fa-times-circle me-2"></i>Marcar No Cotizable</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form id="formNoCotizable">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="clienteIdNoCotizable" name="clienteId" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Cliente</label>
                            <input type="text" class="form-control" id="nombreClienteNoCotizable" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Motivo *</label>
                            <select id="motivoNoCotizable" name="motivo" class="form-select" required>
                                <option value="">-- Seleccione un motivo --</option>
                                <option value="FueraDeZona">Fuera de zona de cobertura</option>
                                <option value="PresupuestoInsuficiente">Presupuesto insuficiente</option>
                                <option value="NoContesta">No contesta / No responde</option>
                                <option value="YaCotizadoOtroProveedor">Ya cotizó con otro proveedor</option>
                                <option value="DatosIncorrectos">Datos de contacto incorrectos</option>
                                <option value="NoInteresado">No está interesado</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Comentario (opcional)</label>
                            <textarea id="comentarioNoCotizable" name="comentario" class="form-control" rows="3" placeholder="Agregue un comentario..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger"><i class="fas fa-ban me-1"></i> Marcar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            cargarUltimosRegistros();

            $('#btnRefrescarUltimos').click(function() {
                cargarUltimosRegistros();
                const icon = $(this).find('i');
                icon.addClass('fa-spin');
                setTimeout(() => icon.removeClass('fa-spin'), 1000);
            });

            setInterval(cargarUltimosRegistros, 60000);

            $(document).on('click', '.btn-ver-detalle', function() {
                const id = $(this).data('id');
                cargarDetalleCliente(id);
                $('#modalDetalleCliente').modal('show');
            });

            $(document).on('click', '.btn-asignar-vendedor', function() {
                const id = $(this).data('id');
                const nombre = $(this).data('nombre');
                $('#clienteIdAsignar').val(id);
                $('#nombreClienteAsignar').val(nombre);
                cargarVendedores();
                $('#modalAsignarVendedor').modal('show');
            });

            $('#formAsignarVendedor').submit(function(e) {
                e.preventDefault();
                const clienteId = $('#clienteIdAsignar').val();
                const vendedorId = $('#vendedorId').val();
                if (!vendedorId) { alert('Seleccione un vendedor'); return; }
                $.ajax({
                    url: '/Recepcion/AsignarVendedor',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                        clienteId: clienteId,
                        vendedorId: vendedorId
                    },
                    success: function(response) {
                        if (response.success) {
                            alert('Vendedor asignado exitosamente');
                            $('#modalAsignarVendedor').modal('hide');
                            cargarUltimosRegistros();
                        } else {
                            alert(response.message || 'Error al asignar vendedor');
                        }
                    },
                    error: function() { alert('Error de conexión'); }
                });
            });

            $(document).on('click', '.btn-no-cotizable', function() {
                const id = $(this).data('id');
                const nombre = $(this).data('nombre');
                $('#clienteIdNoCotizable').val(id);
                $('#nombreClienteNoCotizable').val(nombre);
                $('#modalNoCotizable').modal('show');
            });

            $('#formNoCotizable').submit(function(e) {
                e.preventDefault();
                const clienteId = $('#clienteIdNoCotizable').val();
                const motivo = $('#motivoNoCotizable').val();
                const comentario = $('#comentarioNoCotizable').val();
                if (!motivo) { alert('Seleccione un motivo'); return; }
                $.ajax({
                    url: '/Recepcion/MarcarNoCotizable',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                        clienteId: clienteId,
                        motivo: motivo,
                        comentario: comentario
                    },
                    success: function(response) {
                        if (response.success) {
                            alert('Cliente marcado como no cotizable');
                            $('#modalNoCotizable').modal('hide');
                            $('#motivoNoCotizable').val('');
                            $('#comentarioNoCotizable').val('');
                            cargarUltimosRegistros();
                        } else {
                            alert(response.message || 'Error');
                        }
                    },
                    error: function() { alert('Error de conexión'); }
                });
            });
        });

        function cargarUltimosRegistros() {
            $.ajax({
                url: '/Recepcion/UltimosRegistros',
                type: 'GET',
                success: function(data) { renderizarTablaUltimos(data); },
                error: function() {
                    $('#tbodyUltimosRegistros').html('<tr><td colspan="8" class="text-center text-danger py-3"><i class="fas fa-exclamation-triangle me-2"></i>Error al cargar los registros</td></tr>');
                }
            });
        }

        function renderizarTablaUltimos(clientes) {
            const tbody = $('#tbodyUltimosRegistros');
            $('#contadorUltimos').text(clientes.length);
            if (!clientes || clientes.length === 0) {
                tbody.html('<tr><td colspan="8" class="text-center py-5"><div class="text-muted"><i class="fas fa-clipboard-list fa-4x mb-3" style="opacity: 0.3;"></i><h5>No hay clientes registrados</h5></div></td></tr>');
                return;
            }
            let html = '';
            clientes.forEach(function(cliente) {
                const estadoBadge = getEstadoBadge(cliente.estado);
                const tieneVendedor = cliente.vendedorAsignadoId != null;
                html += `<tr>
                    <td class="ps-3"><span class="badge bg-light text-dark border">${cliente.folio}</span></td>
                    <td><strong>${cliente.nombre}</strong></td>
                    <td>${cliente.telefono || 'N/A'}</td>
                    <td><span class="badge bg-light text-dark">${cliente.origen}</span></td>
                    <td><span class="badge bg-${estadoBadge.color}">${estadoBadge.texto}</span></td>
                    <td>${tieneVendedor ? '<span class="text-success"><i class="fas fa-check-circle me-1"></i>Asignado</span>' : '<span class="text-warning"><i class="fas fa-clock me-1"></i>Sin asignar</span>'}</td>
                    <td><small>${cliente.fechaFormateada || ''}</small></td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-secondary btn-ver-detalle" data-id="${cliente.id}" title="Ver detalle"><i class="fas fa-eye"></i></button>
                            ${!tieneVendedor && cliente.estado === 'SinAsignar' ? `<button class="btn btn-outline-warning btn-asignar-vendedor" data-id="${cliente.id}" data-nombre="${cliente.nombre}" title="Asignar vendedor"><i class="fas fa-user-plus"></i></button>` : ''}
                            <button class="btn btn-outline-danger btn-no-cotizable" data-id="${cliente.id}" data-nombre="${cliente.nombre}" title="Marcar no cotizable"><i class="fas fa-times-circle"></i></button>
                        </div>
                    </td>
                </tr>`;
            });
            tbody.html(html);
        }

        function getEstadoBadge(estado) {
            const estados = {
                'SinAsignar': { color: 'warning', texto: 'Sin Asignar' },
                'Asignado': { color: 'info', texto: 'Asignado' },
                'Contactado': { color: 'primary', texto: 'Contactado' },
                'Cotizado': { color: 'success', texto: 'Cotizado' },
                'NoCotizable': { color: 'danger', texto: 'No Cotizable' },
                'Cerrado': { color: 'dark', texto: 'Cerrado' }
            };
            return estados[estado] || { color: 'secondary', texto: estado };
        }

        function cargarDetalleCliente(id) {
            $.ajax({
                url: '/Recepcion/VerDetalles/' + id,
                type: 'GET',
                success: function(data) { $('#modalDetalleContenido').html(data); },
                error: function() { $('#modalDetalleContenido').html('<div class="alert alert-danger">Error al cargar los detalles</div>'); }
            });
        }

        function cargarVendedores() {
            $.ajax({
                url: '/Recepcion/ObtenerVendedores',
                type: 'GET',
                success: function(data) {
                    let options = '<option value="">-- Seleccione un vendedor --</option>';
                    data.forEach(function(v) { options += `<option value="${v.id}">${v.nombreCompleto} (${v.email})</option>`; });
                    $('#vendedorId').html(options);
                },
                error: function() { alert('Error al cargar vendedores'); }
            });
        }
    </script>
}