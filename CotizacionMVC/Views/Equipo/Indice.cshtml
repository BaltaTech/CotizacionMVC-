@model CotizacionMVC.ViewModels.Equipo.EquipoIndiceViewModel

@{
    ViewData["Title"] = "Catálogo de Equipos HVAC";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-microchip"></i> Catálogo de Equipos</h1>
        <a asp-action="Crear" class="btn btn-primary">
            <i class="fas fa-plus"></i> Agregar Equipo
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["MensajeAdvertencia"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["MensajeAdvertencia"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Equipos.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i> No hay equipos registrados en el catálogo.
            <br />
            <a asp-action="Crear" class="btn btn-primary mt-2">Agregar el primer equipo</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Marca</th>
                        <th>Modelo</th>
                        <th>Capacidad (TR)</th>
                        <th>Precio Base</th>
                        <th>Moneda</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var equipo in Model.Equipos)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-info">@equipo.Marca</span>
                            </td>
                            <td>@equipo.Modelo</td>
                            <td>@equipo.CapacidadToneladas.ToString("N1")</td>
                            <td>@equipo.PrecioBase.ToString("N2")</td>
                            <td>@equipo.MonedaOriginal</td>
                            <td>
                                @if (equipo.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Detalles" asp-route-id="@equipo.Id"
                                       class="btn btn-sm btn-info" title="Ver detalles">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Editar" asp-route-id="@equipo.Id"
                                       class="btn btn-sm btn-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Eliminar" asp-route-id="@equipo.Id"
                                       class="btn btn-sm btn-danger" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
}