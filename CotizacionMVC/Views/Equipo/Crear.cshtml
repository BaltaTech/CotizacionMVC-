@model CotizacionMVC.Models.Entidades.Equipo

@{
    ViewData["Title"] = "Agregar Nuevo Equipo";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h2><i class="fas fa-plus-circle"></i> Agregar Nuevo Equipo</h2>
        </div>
        <div class="card-body">
            <form asp-action="Crear" method="post">
                <!-- Mostrar TODOS los errores de validación -->
                <div asp-validation-summary="All" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="Marca" class="form-label fw-bold">Marca</label>
                        <select name="Marca" class="form-select" asp-items="Html.GetEnumSelectList<CotizacionMVC.Models.Enums.TipoMarca>()">
                            <option value="">Seleccione una marca...</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="Modelo" class="form-label fw-bold">Modelo</label>
                        <input name="Modelo" class="form-control" placeholder="Ej: 4MCW1512A9000AA" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label for="Tipo" class="form-label fw-bold">Tipo</label>
                        <input name="Tipo" class="form-control" placeholder="Ej: MINISPLIT, PISO TECHO" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label for="CapacidadToneladas" class="form-label fw-bold">Capacidad (TR)</label>
                        <input name="CapacidadToneladas" class="form-control" placeholder="Ej: 1.0, 1.5, 2.0" step="0.1" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label for="Tension" class="form-label fw-bold">Tensión</label>
                        <input name="Tension" class="form-control" placeholder="Ej: 110V, 220V" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="Tecnologia" class="form-label fw-bold">Tecnología</label>
                        <input name="Tecnologia" class="form-control" placeholder="Ej: INVERTER R32, ON/OFF R410A" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label for="PrecioBase" class="form-label fw-bold">Precio Base</label>
                        <input name="PrecioBase" class="form-control" placeholder="0.00" step="0.01" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label for="MonedaOriginal" class="form-label fw-bold">Moneda</label>
                        <select name="MonedaOriginal" class="form-select">
                            <option value="">Seleccione...</option>
                            <option value="MXN">MXN - Peso Mexicano</option>
                            <option value="USD">USD - Dólar Americano</option>
                        </select>
                        <small class="text-muted">Trane y York solo en USD. Otras marcas solo en MXN.</small>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Guardar Equipo
                    </button>
                    <a asp-action="Indice" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
}