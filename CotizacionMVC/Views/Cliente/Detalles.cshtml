@model CotizacionMVC.Models.Entidades.Cliente

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2><i class="fas fa-user-circle"></i> Detalles del Cliente</h2>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h4 class="text-primary">Datos Básicos</h4>
                    <dl class="row mt-3">
                        <dt class="col-sm-4">Nombre / Razón Social</dt>
                        <dd class="col-sm-8">@Model.Nombre</dd>

                        @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
                        {
                            <dt class="col-sm-4">Observaciones</dt>
                            <dd class="col-sm-8">@Model.Observaciones</dd>
                        }
                    </dl>
                </div>

                <div class="col-md-6">
                    <h4 class="text-primary">Contacto</h4>
                    <dl class="row mt-3">
                        @if (!string.IsNullOrWhiteSpace(Model.Contacto.NombreContacto))
                        {
                            <dt class="col-sm-4">Nombre de Contacto</dt>
                            <dd class="col-sm-8">@Model.Contacto.NombreContacto</dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.Contacto.Telefono))
                        {
                            <dt class="col-sm-4">Teléfono</dt>
                            <dd class="col-sm-8">@Model.Contacto.Telefono</dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.Contacto.TelefonoMovil))
                        {
                            <dt class="col-sm-4">Teléfono Móvil</dt>
                            <dd class="col-sm-8">@Model.Contacto.TelefonoMovil</dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.Contacto.Correo))
                        {
                            <dt class="col-sm-4">Correo Electrónico</dt>
                            <dd class="col-sm-8">
                                <a href="mailto:@Model.Contacto.Correo">@Model.Contacto.Correo</a>
                            </dd>
                        }
                    </dl>
                </div>
            </div>

            @if (Model.Direccion != null)
            {
                <hr />
                <h4 class="text-primary"><i class="fas fa-map-marker-alt"></i> Dirección</h4>
                <div class="row mt-3">
                    <div class="col-md-12">
                        <p>@Model.Direccion.DireccionCompleta()</p>
                    </div>
                </div>
            }

            <hr />
            <h4 class="text-primary"><i class="fas fa-file-invoice"></i> Cotizaciones</h4>
            @if (Model.Cotizaciones.Any())
            {
                <div class="table-responsive mt-3">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>N° Cotización</th>
                                <th>Empresa</th>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cotizacion in Model.Cotizaciones.OrderByDescending(c => c.FechaCreacion))
                            {
                                <tr>
                                    <td>@cotizacion.NumeroCotizacion</td>
                                    <td>@cotizacion.Empresa?.NombreComercial</td>
                                    <td>@cotizacion.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                    <td>@cotizacion.Total.ToString()</td>
                                    <td>@cotizacion.Estado</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mt-3">Este cliente no tiene cotizaciones aún.</p>
            }
        </div>
        <div class="card-footer">
            <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="fas fa-edit"></i> Editar
            </a>
            <a asp-action="Indice" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver al listado
            </a>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
}