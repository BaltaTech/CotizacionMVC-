@model CotizacionMVC.ViewModels.Cliente.ClienteFormViewModel

@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h2><i class="fas fa-user-edit"></i> Editar Cliente</h2>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Editar">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="All" class="alert alert-danger"></div>

                <h4 class="text-primary mb-3">Datos Básicos</h4>
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="Nombre" class="form-label fw-bold"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                </div>

                <h4 class="text-primary mb-3 mt-4">Contacto</h4>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> El cliente debe tener al menos un medio de contacto
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Telefono" class="form-label"></label>
                        <input asp-for="Telefono" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="TelefonoMovil" class="form-label"></label>
                        <input asp-for="TelefonoMovil" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Correo" class="form-label"></label>
                        <input asp-for="Correo" type="email" class="form-control" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="NombreContacto" class="form-label"></label>
                        <input asp-for="NombreContacto" class="form-control" />
                    </div>
                </div>

                <h4 class="text-primary mb-3 mt-4">Dirección (Opcional)</h4>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Calle" class="form-label"></label>
                        <input asp-for="Calle" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="NumeroExterior" class="form-label"></label>
                        <input asp-for="NumeroExterior" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="NumeroInterior" class="form-label"></label>
                        <input asp-for="NumeroInterior" class="form-control" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Colonia" class="form-label"></label>
                        <input asp-for="Colonia" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Ciudad" class="form-label"></label>
                        <input asp-for="Ciudad" class="form-control" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label asp-for="Estado" class="form-label"></label>
                        <input asp-for="Estado" class="form-control" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label asp-for="CodigoPostal" class="form-label"></label>
                        <input asp-for="CodigoPostal" class="form-control" />
                    </div>
                </div>

                <h4 class="text-primary mb-3 mt-4">Observaciones</h4>
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-save"></i> Guardar Cambios
                    </button>
                    <a asp-action="Indice" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
}