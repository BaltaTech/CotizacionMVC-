@model IEnumerable<CotizacionMVC.Models.Entidades.Cliente>

@{
    ViewData["Title"] = "Clientes";
    var terminoBusqueda = ViewBag.TerminoBusqueda as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-users"></i> Clientes</h1>
        <a asp-action="Crear" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nuevo Cliente
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Búsqueda -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Indice" class="row g-3">
                <div class="col-md-10">
                    <input type="text" name="termino" class="form-control" placeholder="Buscar por nombre, teléfono o email..." value="@terminoBusqueda" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i> No hay clientes registrados.
            <br />
            <a asp-action="Crear" class="btn btn-primary mt-2">Registrar el primer cliente</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Contacto</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Cotizaciones</th>
                        <th>Fecha Registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cliente in Model)
                    {
                        <tr>
                            <td>
                                <strong>@cliente.Nombre</strong>
                                @if (!string.IsNullOrWhiteSpace(cliente.Contacto.NombreContacto))
                                {
                                    <br />
                                    <small class="text-muted">Attn: @cliente.Contacto.NombreContacto</small>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(cliente.Contacto.TelefonoMovil))
                                {
                                    <i class="fas fa-mobile-alt"></i> <span>Móvil</span>
                                }
                                else if (!string.IsNullOrWhiteSpace(cliente.Contacto.Telefono))
                                {
                                    <i class="fas fa-phone"></i> <span>Fijo</span>
                                }
                                else
                                {
                                    <i class="fas fa-envelope"></i> <span>Email</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(cliente.Contacto.TelefonoMovil))
                                {
                                    @cliente.Contacto.TelefonoMovil
                                }
                                else if (!string.IsNullOrWhiteSpace(cliente.Contacto.Telefono))
                                {
                                    @cliente.Contacto.Telefono
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(cliente.Contacto.Correo))
                                {
                                    <a href="mailto:@cliente.Contacto.Correo">@cliente.Contacto.Correo</a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-info">@cliente.Cotizaciones.Count</span>
                            </td>
                            <td>@cliente.FechaRegistro.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-action="Detalles" asp-route-id="@cliente.Id" class="btn btn-sm btn-info" title="Detalles">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Editar" asp-route-id="@cliente.Id" class="btn btn-sm btn-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <a asp-action="Eliminar" asp-route-id="@cliente.Id" class="btn btn-sm btn-danger" title="Eliminar">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                }
                             </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
}