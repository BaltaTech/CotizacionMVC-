@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Identity
@inject IHttpContextAccessor HttpContextAccessor
@inject SignInManager<CotizacionMVC.Models.Entidades.Usuario> SignInManager
@inject UserManager<CotizacionMVC.Models.Entidades.Usuario> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CotizacionMVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CotizacionMVC.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @if (SignInManager.IsSignedIn(User))
    {
        var empresaActivaNombre = Context.Session.GetString("EmpresaActivaNombre") ?? "CotizacionMVC";

        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-snowflake"></i> @empresaActivaNombre
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Inicio</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Equipo" asp-action="Indice">Catálogo de Equipos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Cliente" asp-action="Indice">Clientes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Cotizacion" asp-action="Indice">Cotizaciones</a>
                            </li>
                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Empresa" asp-action="Indice">Empresas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Usuarios" asp-action="Indice">
                                        <i class="fas fa-users-cog"></i> Usuarios
                                    </a>
                                </li>
                            }
                        </ul>
                        <ul class="navbar-nav ms-auto me-3">
                            @{
                                var usuarioActual = await UserManager.GetUserAsync(User);
                                var roles = await UserManager.GetRolesAsync(usuarioActual!);
                                var rolActual = roles.FirstOrDefault() ?? "Usuario";
                            }
                            <li class="nav-item">
                                <span class="nav-link text-dark">
                                    <i class="fas fa-user-circle"></i> Hola, <strong>@usuarioActual!.NombreCompleto</strong>
                                    <span class="badge bg-primary ms-1">@rolActual</span>
                                </span>
                            </li>
                        </ul>

                        <div class="dropdown ms-auto">
                            <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-building"></i> @empresaActivaNombre
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><span class="dropdown-header text-muted">Cambiar a:</span></li>
                                <li>
                                    <form asp-controller="Empresa" asp-action="CambiarEmpresaActiva" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="empresaId" value="d7b0a6c5-e8c8-4b7e-a390-176813056c15" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="dropdown-item">🔷 Aire y Clima</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Empresa" asp-action="CambiarEmpresaActiva" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="empresaId" value="3a7f3e5b-4d3b-407e-8003-094b20c006ee" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="dropdown-item">🌐 Air and Weather</button>
                                    </form>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Autenticacion" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>
        </header>
    }

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CotizacionMVC
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/js/all.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>