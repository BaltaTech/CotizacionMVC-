    @* Notificaciones *@
    <script src="~/js/notificaciones.js" asp-append-version="true"></script>
    
    @* ========== PANEL DE NOTIFICACIONES INTEGRADO ========== *@
    <script>
        (function() {
            var intentos = 0;
            var maxIntentos = 50;
            
            function configurarPanelNotificaciones() {
                if (typeof connection !== 'undefined' && connection.state === 'Connected') {
                    document.getElementById('liNotificaciones').style.display = 'block';
                    
                    connection.on("RecibirNotificacion", function(notificacion) {
                        agregarNotificacionAlPanel(notificacion);
                    });
                    
                    console.log('✅ Panel de notificaciones configurado');
                } else if (intentos < maxIntentos) {
                    intentos++;
                    setTimeout(configurarPanelNotificaciones, 200);
                } else {
                    document.getElementById('liNotificaciones').style.display = 'block';
                    console.warn('⚠️ SignalR no disponible - panel sin conexión en tiempo real');
                }
            }

            function agregarNotificacionAlPanel(notificacion) {
                var badge = document.getElementById('badgeNotificaciones');
                var count = parseInt(badge.textContent) || 0;
                count++;
                badge.textContent = count;
                badge.style.display = 'inline-block';

                var colores = {
                    success: '#28a745',
                    warning: '#ffc107',
                    danger: '#dc3545',
                    info: '#17a2b8'
                };
                var color = colores[notificacion.tipo] || colores.info;
                var icono = notificacion.tipo === 'success' ? 'fa-check-circle' :
                            notificacion.tipo === 'warning' ? 'fa-exclamation-triangle' :
                            notificacion.tipo === 'danger' ? 'fa-times-circle' : 'fa-info-circle';
                
                var ahora = new Date();
                var hora = ahora.getHours().toString().padStart(2, '0') + ':' + 
                           ahora.getMinutes().toString().padStart(2, '0');
                
                var lista = document.getElementById('listaNotificaciones');
                
                var vacio = lista.querySelector('.text-muted.text-center');
                if (vacio) {
                    lista.innerHTML = '';
                }
                
                var item = document.createElement('li');
                item.style.animation = 'slideIn 0.3s ease';
                item.innerHTML = `
                    <a href="/Cotizacion/Indice" class="dropdown-item border-bottom py-3" 
                       style="border-left: 4px solid ${color}; cursor: pointer;">
                        <div class="d-flex align-items-start">
                            <i class="fas ${icono} me-2 mt-1" style="color: ${color};"></i>
                            <div class="flex-grow-1">
                                <strong style="font-size: 0.85rem;">${notificacion.titulo}</strong>
                                <p class="mb-1 small text-muted">${notificacion.mensaje}</p>
                                <small class="text-muted">
                                    <i class="far fa-clock me-1"></i>${hora}
                                </small>
                            </div>
                        </div>
                    </a>`;
                
                lista.insertBefore(item, lista.firstChild);
                
                var items = lista.querySelectorAll('li');
                if (items.length > 10) {
                    lista.removeChild(items[items.length - 1]);
                }

                if (window.navigator && window.navigator.vibrate) {
                    window.navigator.vibrate(200);
                }
            }

            document.addEventListener('DOMContentLoaded', function() {
                setTimeout(configurarPanelNotificaciones, 500);
                
                document.addEventListener('click', function(e) {
                    if (e.target.closest('#btnLimpiarNotificaciones')) {
                        var badge = document.getElementById('badgeNotificaciones');
                        badge.textContent = '0';
                        badge.style.display = 'none';
                        
                        var lista = document.getElementById('listaNotificaciones');
                        lista.innerHTML = `
                            <li>
                                <span class="dropdown-item text-muted text-center py-4">
                                    <i class="fas fa-inbox fa-3x mb-2" style="opacity: 0.2;"></i><br>
                                    <small>No hay notificaciones nuevas</small>
                                </span>
                            </li>`;
                    }
                });
            });
        })();
    </script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* Copos de nieve animados *@
    <script>
        const emojis = ['❄', '❅', '❆', '✦', '✧'];
        const container = document.getElementById('snowflakes');
        for (let i = 0; i < 15; i++) {
            const flake = document.createElement('span');
            flake.className = 'snowflake';
            flake.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];
            flake.style.left = Math.random() * 100 + '%';
            flake.style.animationDuration = (Math.random() * 10 + 10) + 's';
            flake.style.animationDelay = Math.random() * 15 + 's';
            flake.style.fontSize = (Math.random() * 15 + 10) + 'px';
            container.appendChild(flake);
        }
    </script>
</body>
</html>