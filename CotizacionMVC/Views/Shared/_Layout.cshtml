@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Identity
@inject IHttpContextAccessor HttpContextAccessor
@inject SignInManager<CotizacionMVC.Models.Entidades.Usuario> SignInManager
@inject UserManager<CotizacionMVC.Models.Entidades.Usuario> UserManager

@{
    var colorPrimario = Context.Session.GetString("EmpresaColorPrimario") ?? "#C8102E";
    var colorSecundario = Context.Session.GetString("EmpresaColorSecundario") ?? "#FFFFFF";
    
    // Calcular variaciones del color primario
    var r = Convert.ToInt32(colorPrimario.Substring(1, 2), 16);
    var g = Convert.ToInt32(colorPrimario.Substring(3, 2), 16);
    var b = Convert.ToInt32(colorPrimario.Substring(5, 2), 16);
    
    var rOscuro = (int)(r * 0.7);
    var gOscuro = (int)(g * 0.7);
    var bOscuro = (int)(b * 0.7);
    var colorOscuro = $"#{rOscuro:X2}{gOscuro:X2}{bOscuro:X2}";
    
    var rClaro = Math.Min(255, (int)(r * 1.2 + 30));
    var gClaro = Math.Min(255, (int)(g * 1.2 + 30));
    var bClaro = Math.Min(255, (int)(b * 1.2 + 30));
    var colorClaro = $"#{rClaro:X2}{gClaro:X2}{bClaro:X2}";
    
    var empresaActivaNombre = Context.Session.GetString("EmpresaActivaNombre") ?? "Todas las empresas";}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @empresaActivaNombre</title>
    
    @* Bootstrap *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    @* Font Awesome *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    @* Estilos personalizados *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CotizacionMVC.styles.css" asp-append-version="true" />
    
    @await RenderSectionAsync("Styles", required: false)
    
    <style>
        :root {
            --color-primario: @colorPrimario;
            --color-oscuro: @colorOscuro;
            --color-claro: @colorClaro;
            --color-secundario: @colorSecundario;
        }

        body {
            background: #F8F9FA;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        .navbar-hvac {
            background: linear-gradient(135deg, var(--color-primario) 0%, var(--color-oscuro) 100%) !important;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
        }

        .navbar-hvac .navbar-brand {
            color: white !important;
            font-weight: 700;
            font-size: 1.3rem;
        }

        .navbar-hvac .nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
            font-weight: 500;
            transition: all 0.3s ease;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            margin: 0 2px;
        }

        .navbar-hvac .nav-link:hover {
            color: white !important;
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
        }

        .badge-notificacion {
            position: absolute;
            top: 2px;
            right: 2px;
            font-size: 0.6rem;
            background: #FFD700 !important;
            color: var(--color-primario) !important;
        }

        /* Campanita de notificaciones */
        #liNotificaciones .nav-link {
            position: relative;
        }

        #badgeNotificaciones {
            position: absolute;
            top: 0px;
            right: -2px;
            font-size: 0.6rem;
            background: #FFD700 !important;
            color: var(--color-primario) !important;
            animation: pulseBadge 2s infinite;
        }

        @@keyframes pulseBadge {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.3); }
        }

        #listaNotificaciones .dropdown-item:hover {
            background-color: #f8f9fa;
        }

        .btn-empresa {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .btn-empresa:hover {
            background: rgba(255, 255, 255, 0.25);
            color: white;
        }

        .footer-hvac {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            color: rgba(255, 255, 255, 0.7);
            padding: 1rem 0;
            font-size: 0.85rem;
        }

        /* Toast de notificación */
        .toast-notificacion {
            position: fixed;
            top: 20px;
            right: 20px;
            background: white;
            border-left: 4px solid #28a745;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            padding: 15px 20px;
            border-radius: 8px;
            z-index: 99999;
            min-width: 300px;
            max-width: 400px;
        }

        @@keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        @@keyframes fadeOut {
            from { opacity: 1; }
            to { opacity: 0; }
        }

        .snowflake-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .snowflake {
            position: absolute;
            color: var(--color-primario);
            opacity: 0.06;
            animation: snowflake linear infinite;
        }

        @@keyframes snowflake {
            0% { transform: translateY(-10px) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            100% { transform: translateY(100vh) rotate(360deg); opacity: 0; }
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: var(--color-primario); border-radius: 4px; }

        /* Scrollbar para el dropdown de notificaciones */
        #listaNotificaciones::-webkit-scrollbar { width: 4px; }
        #listaNotificaciones::-webkit-scrollbar-track { background: transparent; }
        #listaNotificaciones::-webkit-scrollbar-thumb { background: var(--color-primario); border-radius: 2px; }

        .dropdown-header i {
            color: var(--color-primario) !important;
        }
        
        .btn-outline-danger {
            color: var(--color-primario);
            border-color: var(--color-primario);
        }
        
        .btn-outline-danger:hover {
            background-color: var(--color-primario);
            color: white;
        }
    </style>
</head>
