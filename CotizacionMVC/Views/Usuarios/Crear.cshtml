@model CotizacionMVC.Controllers.CrearUsuarioViewModel
@{
    ViewData["Title"] = "Nuevo Usuario";
    var roles = ViewBag.Roles as List<string>;
}

<h2><i class="fas fa-user-plus"></i> @ViewData["Title"]</h2>

<form asp-action="Crear" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="NombreCompleto" class="form-label"></label>
        <input asp-for="NombreCompleto" class="form-control" />
        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" type="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Rol" class="form-label"></label>
        <select asp-for="Rol" class="form-select">
            <option value="">-- Seleccionar Rol --</option>
            @if (roles != null)
            {
                foreach (var rol in roles)
                {
                    <option value="@rol">@rol</option>
                }
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Crear Usuario</button>
    <a asp-action="Indice" class="btn btn-secondary">Cancelar</a>
</form>